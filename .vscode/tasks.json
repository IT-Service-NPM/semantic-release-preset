	"tasks": [
		{
			"label": "Install dependencies",
			"type": "shell",
			"command": "pnpm install --recursive",
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"reveal": "always",
				"clear": true,
				"close": true,
				"panel": "dedicated"
			}
		}
	]
}
