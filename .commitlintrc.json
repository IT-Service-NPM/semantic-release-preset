{
	"extends": [
		"@commitlint/config-angular"
	],
	"rules": {
		"type-enum": [
			2,
			"always",
			[
				"build",
				"ci",
				"docs",
				"feat",
				"fix",
				"perf",
				"refactor",
				"revert",
				"style",
				"test",
				"chore"
			]
		],
		"scope-enum": [
			2,
			"always",
			[
				"plugin",
				"vscode",
				"git",
				"github",
				"github-actions",
				"deps",
				"devtools",
				"readme",
				"release"
			]
		],
		"scope-empty": [
			0
		]
	}
}
