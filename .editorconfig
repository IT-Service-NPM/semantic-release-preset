; Check http://editorconfig.org/ for more information
; Top-most EditorConfig file
root = true

[*]
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

[*.{editorconfig,gitattributes,gitignore}]

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2

; fix linting error for generated files
[docs/**/*.md]
trim_trailing_whitespace = false

[{LICENSE,NOTICE}]
indent_style = space
indent_size = 2

[*.{js,mjs,cjs,ts,tsx}]
indent_style = space
indent_size = 2

[*.json]
indent_style = tab
indent_size = 2
